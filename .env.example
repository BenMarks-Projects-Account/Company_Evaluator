# Company Evaluator Configuration

# Server
HOST=0.0.0.0
PORT=8100
DEBUG=true

# Database
DATABASE_URL=sqlite:///db/company_eval.db

# LLM (LM Studio on same machine)
LLM_ENDPOINT=http://localhost:1234/v1/chat/completions
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.0

# Data Sources
YAHOO_RATE_LIMIT=2.0

# FMP (Financial Modeling Prep) — cross-validator + Polygon fallback
# FMP_API_KEY=your_fmp_api_key_here
# FMP_ENABLED=true
# FMP_RATE_LIMIT_PER_MIN=300
# FMP_BASE_URL=https://financialmodelingprep.com/stable

# Pipeline
UNIVERSE=sp500_top100
CRAWLER_ENABLED=false
CRAWLER_SCHEDULE=02:00
EVALUATION_BATCH_SIZE=10
